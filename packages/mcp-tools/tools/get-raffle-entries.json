{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.freeside.thj/mcp/get-raffle-entries/v1.0.0",
  "title": "get-raffle-entries",
  "description": "Returns the page of RaffleEntry events for a cycle, optionally scoped to an identity.",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "required": ["cycle_id"],
      "additionalProperties": false,
      "properties": {
        "cycle_id": {
          "type": "string",
          "pattern": "^cycle_[a-z0-9]{1,128}$"
        },
        "identity_id": {
          "type": ["string", "null"],
          "pattern": "^id_[a-z0-9]{1,128}$|^$"
        },
        "_pagination": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cursor": { "type": ["string", "null"] },
            "limit": { "type": "integer", "minimum": 1, "maximum": 200 }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["items", "next_cursor", "total_count"],
      "additionalProperties": false,
      "properties": {
        "items": {
          "type": "array",
          "items": { "$ref": "https://schemas.freeside.thj/raffle-drawn/v1.0.0" }
        },
        "next_cursor": { "type": ["string", "null"] },
        "total_count": { "type": ["integer", "null"] }
      }
    }
  },
  "required": ["input", "output"]
}

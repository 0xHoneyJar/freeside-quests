{
  "name": "@0xhoneyjar/freeside-activities-mcp-tools",
  "version": "0.1.0",
  "private": false,
  "description": "MCP tool surface for the activities substrate — manifest + 5 read-only tool specs + auth (bearer-token + world-scope + rate-limit + audit log) + pagination (signed cursors).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifest": "./manifest.json",
    "./tools/*.json": "./tools/*.json"
  },
  "files": ["dist", "src", "tools", "manifest.json", "README.md"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xHoneyJar/freeside-activities.git",
    "directory": "packages/mcp-tools"
  },
  "homepage": "https://github.com/0xHoneyJar/freeside-activities/tree/master/packages/mcp-tools#readme",
  "bugs": {
    "url": "https://github.com/0xHoneyJar/freeside-activities/issues"
  },
  "keywords": ["freeside", "activities", "mcp", "agent", "effect"],
  "peerDependencies": {
    "@0xhoneyjar/quests-protocol": "workspace:*",
    "effect": "^3.12.0"
  },
  "devDependencies": {
    "@0xhoneyjar/quests-protocol": "workspace:*",
    "effect": "^3.12.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

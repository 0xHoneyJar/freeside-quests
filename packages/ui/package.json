{
  "name": "@0xhoneyjar/quests-ui",
  "version": "0.1.0",
  "private": false,
  "description": "Unstyled React primitives for quest UIs — slot-based composition, zero CSS, zero design tokens. Consumers (cubquests-dashboard · per-world bots · future Farcaster Mini App) ship their own skin. Per Cycle Q SDD §6 + PRD D2 anti-pattern guard.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xHoneyJar/freeside-quests.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/0xHoneyJar/freeside-quests/tree/master/packages/ui#readme",
  "bugs": {
    "url": "https://github.com/0xHoneyJar/freeside-quests/issues"
  },
  "keywords": [
    "freeside",
    "quests",
    "react",
    "unstyled",
    "primitives"
  ],
  "dependencies": {
    "@0xhoneyjar/quests-protocol": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "happy-dom": "^15.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}

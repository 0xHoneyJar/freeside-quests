{
  "name": "@freeside-quests/discord-renderer",
  "version": "0.1.0",
  "private": true,
  "description": "Discord-component descriptor emitter for quest interactions. Emits APIInteractionResponse descriptors — does NOT dispatch (the bot owns dispatch). Cross-bot installable per [[freeside-modules-as-installables]]. Per Cycle Q SDD §5 + PRD D1.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@freeside-quests/protocol": "workspace:*",
    "@freeside-quests/engine": "workspace:*"
  },
  "peerDependencies": {
    "discord-api-types": "^0.37.0",
    "effect": "^3.10.0"
  },
  "devDependencies": {
    "discord-api-types": "^0.37.100",
    "effect": "^3.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}

{
  "name": "@0xhoneyjar/quests-discord-renderer",
  "version": "0.1.1",
  "private": false,
  "description": "Discord-component descriptor emitter for quest interactions. Emits APIInteractionResponse descriptors — does NOT dispatch (the bot owns dispatch). Cross-bot installable per [[freeside-modules-as-installables]]. Per Cycle Q SDD §5 + PRD D1.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xHoneyJar/freeside-quests.git",
    "directory": "packages/discord-renderer"
  },
  "homepage": "https://github.com/0xHoneyJar/freeside-quests/tree/master/packages/discord-renderer#readme",
  "bugs": {
    "url": "https://github.com/0xHoneyJar/freeside-quests/issues"
  },
  "keywords": [
    "freeside",
    "quests",
    "discord",
    "interaction-response"
  ],
  "dependencies": {
    "@0xhoneyjar/quests-protocol": "^0.1.1",
    "@0xhoneyjar/quests-engine": "^0.1.1"
  },
  "peerDependencies": {
    "discord-api-types": "^0.37.0",
    "effect": "^3.10.0"
  },
  "devDependencies": {
    "discord-api-types": "^0.37.100",
    "effect": "^3.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}

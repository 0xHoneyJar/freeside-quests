{
  "name": "@freeside-quests/engine",
  "version": "0.1.0",
  "private": true,
  "description": "Headless quest engine — substrate-step dispatch bridging (gateway → construct → resolution) + future quest publish/query/complete/claim flows. Framework-agnostic. The construct is OPENED via Effect Requirements; consumers plug in their own grader.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@freeside-quests/protocol": "workspace:*"
  },
  "peerDependencies": {
    "effect": "^3.10.0",
    "pg": "^8.11.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "effect": "^3.10.0",
    "pg": "^8.11.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}

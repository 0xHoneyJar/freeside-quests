{
  "name": "freeside-activities",
  "version": "0.1.0",
  "private": true,
  "description": "Activity substrate for freeside-* modules — sealed Effect.Schema protocol (Activity, ActivityKind, ActivityReward, EventEnvelope, computeEventId), typed ports (Progress, CompletionEvent, Reward, IdentityResolver), in-memory adapters, read-only MCP tools, headless engine. Cycle: acvp-modules-genesis.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xHoneyJar/freeside-activities.git"
  },
  "workspaces": [
    "packages/protocol",
    "packages/ports",
    "packages/adapters",
    "packages/mcp-tools",
    "packages/engine",
    "packages/ui",
    "packages/discord-renderer"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["bun"],
    "paths": {
      "@hyper/*": ["./src/hyper/*", "./src/hyper/*/index.ts"],
      "@0xhoneyjar/quests-protocol": ["../../packages/protocol/src/index.ts"],
      "@0xhoneyjar/freeside-activities-adapters": ["../../packages/adapters/src/index.ts"],
      "@0xhoneyjar/freeside-activities-adapters/postgres": ["../../packages/adapters/src/postgres/index.ts"],
      "@0xhoneyjar/quests-engine": ["../../packages/engine/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/hyper/**"]
}
